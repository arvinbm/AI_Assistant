# Application
ENVIRONMENT=dev

# AWS credentials & region
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Document storage
S3_BUCKET=your-document-bucket
# Set to true only when the AWS values above are real; otherwise files
# are saved to the local uploads/ folder for development.
USE_S3=false

# AWS Bedrock model IDs
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_GENERATION_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
